{
  "$defs": {
    "ConfidentialityHorizon": {
      "description": "Expected confidentiality horizon of task data.",
      "enum": [
        "short",
        "medium",
        "long"
      ],
      "title": "ConfidentialityHorizon",
      "type": "string"
    },
    "NetworkClass": {
      "description": "Network environment class for the task descriptor public context.",
      "enum": [
        "stable_cloud",
        "enterprise_wan",
        "constrained_edge"
      ],
      "title": "NetworkClass",
      "type": "string"
    },
    "OperationalImpact": {
      "description": "Operational impact class of the task descriptor public context.",
      "enum": [
        "observation",
        "business_action",
        "physical_control"
      ],
      "title": "OperationalImpact",
      "type": "string"
    },
    "TaskSensitivity": {
      "description": "Sensitivity class of the task descriptor public context.",
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ],
      "title": "TaskSensitivity",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Monotone lower-bound task predicates plus exact unordered class filters.",
  "properties": {
    "minimum_confidentiality_horizon": {
      "anyOf": [
        {
          "$ref": "#/$defs/ConfidentialityHorizon"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "minimum_delegation_depth": {
      "anyOf": [
        {
          "maximum": 8,
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Minimum Delegation Depth"
    },
    "minimum_expected_session_seconds": {
      "anyOf": [
        {
          "maximum": 86400,
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Minimum Expected Session Seconds"
    },
    "minimum_operational_impact": {
      "anyOf": [
        {
          "$ref": "#/$defs/OperationalImpact"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "minimum_sensitivity": {
      "anyOf": [
        {
          "$ref": "#/$defs/TaskSensitivity"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "network_classes": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/NetworkClass"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Network Classes"
    },
    "organization_policy_classes": {
      "anyOf": [
        {
          "items": {
            "maxLength": 64,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._-]+$",
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Organization Policy Classes"
    }
  },
  "title": "TaskRuleCondition",
  "type": "object"
}
